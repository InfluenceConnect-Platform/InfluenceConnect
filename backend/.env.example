# Server
PORT=8000

# Database (we'll fill this later)
DATABASE_URL=your_database_url_here

# JWT Secret (we'll fill this later)
JWT_SECRET=your_jwt_secret_here

# Initial admin bootstrap (used only by scripts/createAdmin.js to seed the first
# admin account). Set these to your own values, then run `node scripts/createAdmin.js`.
# After first login, change the email/password from the in-app Admin Settings page.
ADMIN_NAME=Influence Connect Admin
ADMIN_EMAIL=admin@example.com
ADMIN_MOBILE=+910000000000
ADMIN_PASSWORD=change_this_secure_password

# ── Email (Resend) ──
# RESEND_API_KEY powers OTP + transactional emails.
RESEND_API_KEY=your_resend_api_key_here
# Verified sender once your domain is set up in Resend (defaults to Resend's
# test sender, which only delivers to the account owner).
EMAIL_FROM=Influence Connect <onboarding@resend.dev>
# Master switch for the transactional emails (welcome, applications, deals,
# messages…). Leave false until Resend is production-ready; the trigger points
# are already wired and will start delivering the moment this is flipped to true.
EMAILS_ENABLED=false
# Base URL used to build links inside emails (CTA buttons).
APP_URL=http://localhost:3000
# Dev only: redirect every outgoing email to this single inbox (Resend test mode
# only delivers to the account owner). Leave unset in production.
DEV_OTP_EMAIL=

# ── Payout details encryption ──
# 32-byte key (hex or base64) used to encrypt influencer bank account
# number / IFSC / UPI ID at rest. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this key after data has been submitted makes existing payout
# details undecryptable — treat it like any other production secret.
PAYOUT_ENCRYPTION_KEY=your_32_byte_hex_key_here