# Server
PORT=8000

# Database (we'll fill this later)
DATABASE_URL=your_database_url_here

# JWT Secret (we'll fill this later)
JWT_SECRET=your_jwt_secret_here

# Initial admin bootstrap (used only by scripts/createAdmin.js to seed the first
# admin account). Set these to your own values, then run `node scripts/createAdmin.js`.
# After first login, change the email/password from the in-app Admin Settings page.
ADMIN_NAME=Influence Connect Admin
ADMIN_EMAIL=admin@example.com
ADMIN_MOBILE=+910000000000
ADMIN_PASSWORD=change_this_secure_password