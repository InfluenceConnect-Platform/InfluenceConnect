# Server
PORT=8000
NODE_ENV=development

# Database
MONGODB_URI=your_mongodb_connection_string_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# URLs
# Base URL used to build links inside emails (CTA buttons).
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# Production frontend origin, added to the CORS allow-list (see index.js).
FRONTEND_URL=

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Cloudinary (uploads: profile photos, campaign assets, message attachments) ──
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ── Razorpay (Premium checkout) ──
# Sandbox keys (rzp_test_...) for now; swap for rzp_live_... once the client
# provides production keys — Razorpay infers test/live from the key prefix,
# no code changes needed. Get these + the webhook secret from the Razorpay
# Dashboard (Settings > API Keys, and Settings > Webhooks for the secret).
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── Cron (Vercel Cron -> /api/payments/reconcile) ──
# Vercel automatically sends `Authorization: Bearer $CRON_SECRET` on cron
# requests when this var is set on the project — generate any random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_random_secret_here

# ── Initial admin bootstrap (used only by scripts/createAdmin.js to seed the
# first admin account). Set these to your own values, then run
# `node scripts/createAdmin.js`. After first login, change the email/password
# from the in-app Admin Settings page.
ADMIN_NAME=Influence Connect Admin
ADMIN_EMAIL=admin@example.com
ADMIN_MOBILE=+910000000000
ADMIN_PASSWORD=change_this_secure_password

# ── Email (Resend) ──
# RESEND_API_KEY powers OTP + transactional emails. Configure once the
# production domain is purchased and verified in Resend.
RESEND_API_KEY=your_resend_api_key_here
# Verified sender once your domain is set up in Resend (defaults to Resend's
# test sender, which only delivers to the account owner).
EMAIL_FROM=Influence Connect <onboarding@resend.dev>
# Master switch for the transactional emails (welcome, applications, deals,
# messages…). Leave false until Resend is production-ready; the trigger points
# are already wired and will start delivering the moment this is flipped to true.
EMAILS_ENABLED=false
# Dev only: redirect every outgoing email to this single inbox (Resend test mode
# only delivers to the account owner). Leave unset in production.
DEV_OTP_EMAIL=

# ── Payout details encryption ──
# 32-byte key (hex or base64) used to encrypt influencer bank account
# number / IFSC / UPI ID at rest. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this key after data has been submitted makes existing payout
# details undecryptable — treat it like any other production secret.
PAYOUT_ENCRYPTION_KEY=your_32_byte_hex_key_here

# ── Content Security Policy ──
CSP_ENABLED=false
